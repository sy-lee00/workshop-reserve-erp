<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.dia.dao.BannerDAO">

    <resultMap id="bannerMap" type="com.project.dia.model.vo.Banner">
        <id property="bannerId" column="banner_id"/>
        <result property="adminId" column="admin_id"/>
        <result property="title" column="title"/>
        <result property="image" column="image"/>
        <result property="link" column="link"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="active" column="active"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 1. 모든 배너 가져오기 -->
    <select id="selectAllBanners" resultMap="bannerMap">
        SELECT *
        FROM banner
        ORDER BY sort_order ASC
    </select>

    <!-- 2. 배너 추가 -->
    <insert id="insertBanner" parameterType="com.project.dia.model.vo.Banner">
        INSERT INTO banner (admin_id, title, image, link, sort_order, active)
        VALUES (#{adminId}, #{title}, #{image}, #{link}, #{sortOrder}, #{active})
    </insert>

    <!-- 3. 배너 수정 -->
    <update id="updateBanner" parameterType="com.project.dia.model.vo.Banner">
        UPDATE banner
        SET title = #{title},
        image = #{image},
        link = #{link},
        sort_order = #{sortOrder},
        active = #{active}
        WHERE banner_id = #{bannerId}
    </update>

    <!-- 4. 배너 삭제 -->
    <delete id="deleteBanner" parameterType="int">
        DELETE FROM banner WHERE banner_id = #{bannerId}
    </delete>

    <!-- 5. sort_order만 변경 -->
    <update id="updateSortOrder">
        UPDATE banner
        SET sort_order = #{sortOrder}
        WHERE banner_id = #{bannerId}
    </update>

    <select id="selectOneBanner" parameterType="int" resultMap="bannerMap">
        SELECT * FROM banner WHERE banner_id = #{bannerId}
    </select>
    <update id="updateBannerActive" >
            UPDATE banner
            SET active = #{active}
            WHERE banner_id = #{bannerId}
    </update>


</mapper>
