<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.dia.dao.UserDAO">

    <select id="selectOne" parameterType="int" resultType="User">
        select
        *
        from user
        where user_id = #{userId}
    </select>

    <update id="modifyUser" parameterType="User">
        update user
        set
        email = #{email},
        name = #{name},
        phone = #{phone}
        where
        user_id = #{userId}
    </update>

    <update id="profileUser" parameterType="User">
        UPDATE user
        SET profile_img = #{profileImg}
        WHERE user_id = #{userId}
    </update>

    <update id="quitUser" parameterType="int">
        update user
        set
        active = false
        where
        user_id = #{userId}
    </update>

    <insert id="registerUser" parameterType="User">
        insert into user(email, password, name, role, phone)
        values(#{email}, #{password}, #{name}, #{role}, #{phone})
    </insert>

    <select id="userEmail" parameterType="String" resultType="User">
        select * from user
        where email=#{email}
    </select>

    <update id="changePwd" parameterType="User">
        update user set password = #{password} where email = #{email}
    </update>

    <select id="adminList" resultType="User">
        SELECT * FROM user WHERE role='admin'
    </select>

    <select id="userList" resultType="User">
        SELECT * FROM user WHERE role != 'admin'
    </select>

</mapper>